[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=image/jpeg;image/jpg;image/png;image/webp;image/gif;image/bmp;image/tiff;
Actions=setWallpaper;

[Desktop Action setWallpaper]
Name=Wallpaper Olarak Ayarla
Name[en]=Set as Wallpaper
Icon=preferences-desktop-wallpaper
Exec=/home/alperenkirca/.local/bin/set-wallpaper.sh %f
